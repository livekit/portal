# Copy to `.env` and fill in your LiveKit credentials.
#
# The policy runs on Modal and dials OUT to LiveKit, so this must be a
# publicly reachable server, LiveKit Cloud or your own hosted instance.
# A localhost devserver won't work: Modal can't reach it.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
